{
    "name": "FlixTools",
    "version": "0.1.0",
    "main": "node_modules/expo/AppEntry.js",
    "scripts": {
        "export:web": "expo export:web",
        "start": "expo start",
        "start:android": "expo start --android",
        "start:ios": "expo start --ios",
        "start:web": "expo start --web",
        "start:electron": "onchange '**/*.{html,js,jsx,md,mdx,svelte,ts,tsx,vue,scss,sass}' -- expo export:web && electron ./electron/main.js",
        "lint:prettier": "prettier --write '**/*.{html,js,json,jsx,md,mdx,svelte,ts,tsx,vue,scss,sass}'",
        "electron:dev": "yarn export:web && electron ./electron/main.js"
    },
    "dependencies": {
        "@react-navigation/native": "^6.1.1",
        "@react-navigation/native-stack": "^6.9.6",
        "@reduxjs/toolkit": "^1.9.1",
        "expo": "~47.0.8",
        "expo-status-bar": "~1.4.2",
        "nativewind": "^2.0.11",
        "postcss-loader": "4.2.0",
        "react": "18.1.0",
        "react-dom": "18.1.0",
        "react-native": "0.70.5",
        "react-native-safe-area-context": "4.4.1",
        "react-native-screens": "~3.18.0",
        "react-native-web": "~0.18.9"
    },
    "devDependencies": {
        "@babel/core": "^7.12.9",
        "@expo/webpack-config": "^0.17.3",
        "@types/react": "~18.0.14",
        "@types/react-native": "~0.70.6",
        "electron": "^22.0.0",
        "onchange": "^7.1.0",
        "tailwindcss": "^3.2.4",
        "typescript": "^4.6.3"
    },
    "private": true,
    "homepage": "./"
}
